# TangkuAgentOS Configuration Example
# Copy this file to config.yaml and customize it for your needs.

# Kernel Configuration
kernel:
  name: "TangkuAgentOS"
  version: "1.0.0b2"
  debug: false
  log_level: "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Provider Runtime Configuration
providers:
  # OpenAI Provider
  openai:
    enabled: true
    api_key: "${OPENAI_API_KEY}"  # Set via environment variable
    base_url: "https://api.openai.com/v1"
    default_model: "gpt-3.5-turbo"
    timeout: 30  # seconds
    max_retries: 3
    rate_limit: 100  # requests per minute

  # Anthropic Provider
  anthropic:
    enabled: false
    api_key: "${ANTHROPIC_API_KEY}"
    base_url: "https://api.anthropic.com/v1"
    default_model: "claude-3-sonnet-20240229"
    timeout: 30
    max_retries: 3

  # Local Provider (for local LLMs)
  local:
    enabled: false
    model_path: "/path/to/local/model"
    backend: "llama"  # or "mistral", "phi", "gemma", etc.
    max_context_length: 2048
    temperature: 0.7
    top_p: 0.9

# Memory Engine Configuration
memory:
  enabled: true
  backend: "vector"  # or "sql", "redis"
  
  # Vector DB Configuration
  vector_db:
    type: "faiss"  # or "chroma"
    index_path: "./data/memory_index"
    dimension: 768  # Embedding dimension
    max_index_size: 100000  # Maximum number of vectors
    
  # SQL Configuration (if backend is "sql")
  sql:
    database_url: "sqlite:///./data/memory.db"
    max_connections: 10
    
  # Redis Configuration (if backend is "redis")
  redis:
    host: "localhost"
    port: 6379
    db: 0
    password: ""

# Workflow Engine Configuration
workflow:
  enabled: true
  max_concurrent_workflows: 10
  default_timeout: 300  # 5 minutes
  retry_on_failure: true
  max_retries: 3
  retry_delay: 1  # seconds between retries

# Runtime Configuration
runtimes:
  - name: "provider_runtime"
    enabled: true
    dependencies: []
    
  - name: "memory_engine"
    enabled: true
    dependencies: []
    
  - name: "workflow_engine"
    enabled: true
    dependencies: ["provider_runtime", "memory_engine"]
    
  - name: "agent_runtime"
    enabled: false
    dependencies: ["provider_runtime", "memory_engine", "workflow_engine"]

# Event Bus Configuration
event_bus:
  enabled: true
  max_queue_size: 1000
  worker_count: 4
  priority_levels: 4  # Number of priority levels

# Health Monitor Configuration
health_monitor:
  enabled: true
  check_interval: 5  # seconds between health checks
  alert_on_failure: true
  alert_callbacks: []  # List of callbacks for alerts

# API Server Configuration (if enabled)
api:
  enabled: false
  host: "0.0.0.0"
  port: 8000
  debug: false
  cors_origins: ["*"]
  
  # Authentication (optional)
  auth:
    enabled: false
    api_key: "${API_AUTH_KEY}"

# CLI Configuration
cli:
  color_output: true
  verbose: false
  default_config: "./config.yaml"

# Logging Configuration
logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  file: "./logs/tangku_agentos.log"
  max_file_size: 10485760  # 10MB
  backup_count: 5

# Security Configuration
security:
  sandbox_enabled: true
  plugin_sandbox: "docker"  # or "gvisor", "none"
  input_validation: true
  max_input_length: 10000

# Performance Configuration
performance:
  max_concurrent_requests: 100
  request_timeout: 30  # seconds
  cache_enabled: true
  cache_ttl: 3600  # 1 hour in seconds

# Debug Configuration
debug:
  trace_events: false
  profile_performance: false
  log_all_events: false
